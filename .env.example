# Application
SPRING_PROFILES_ACTIVE=local
SPRING_DOCKER_COMPOSE_ENABLED=true
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soomgil
DB_USERNAME=soomgil
DB_PASSWORD=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT: 운영에서는 32바이트 이상의 무작위 값을 Base64로 인코딩해 교체하세요.
JWT_SECRET=Y2hhbmdlLW1lLWxvY2FsLWRldi1zZWNyZXQtZm9yLWp3dC1oczI1Ni1vbmx5
JWT_ISSUER=soomgil
JWT_ACCESS_TOKEN_TTL_SECONDS=900

# Mailpit
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_WEB_PORT=8025
MAIL_USERNAME=
MAIL_PASSWORD=

# OAuth: 실제 키는 .env에만 넣고 Git에 올리지 마세요.
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/auth/oauth/kakao/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/oauth/google/callback

# Gemini: AI 채팅과 장소 태깅이 같은 모델을 공유합니다.
# Gemini API 키 발급: https://aistudio.google.com/apikey
AI_CHAT_MODEL=google-genai
GEMINI_API_KEY=change-me
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite

# Korea Tourism Organization
KTO_API_BASE_URL=https://apis.data.go.kr/B551011/KorService2
KTO_API_KEY=change-me

# Mapbox
MAPBOX_API_BASE_URL=https://api.mapbox.com
MAPBOX_ACCESS_TOKEN=change-me

# MinIO / S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-northeast-2
S3_BUCKET=soomgil-local
S3_PUBLIC_BASE_URL=http://localhost:9000/soomgil-local
S3_PORT=9000
S3_CONSOLE_PORT=9001
S3_ACCESS_KEY=soomgil
S3_SECRET_KEY=change-me-change-me
